# OpenAI credentials
OPENAI_API_KEY=sk-...

# Vector stores (one per retailer). Run upload_to_openai_vectorstore.js to create them.
TARGET_VECTOR_STORE_ID=vs_...
AMAZON_VECTOR_STORE_ID=vs_...
WALMART_VECTOR_STORE_ID=vs_...

# Legacy alias for TARGET_VECTOR_STORE_ID (kept for backward compat)
VECTOR_STORE_ID=vs_...

# Realtime model + voice
REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
REALTIME_VOICE=alloy
RETRIEVAL_MODEL=gpt-4o-mini

# Local server
PORT=3000

# Voice tuning — interruption handling, brevity, token budget
TURN_THRESHOLD=0.5
TURN_PREFIX_PADDING_MS=200
TURN_SILENCE_MS=400
TEMPERATURE=0.7
MAX_RESPONSE_TOKENS=200

# Basic Auth (set BASIC_AUTH_PASS to enable; leave empty to disable for local dev)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
